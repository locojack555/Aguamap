fun finishGame() {
    viewModelScope.launch {
        val f = _currentFountain.value ?: return@launch
        val g = _userGuessPos.value

        if (g == null) { handleLoss(); return@launch }

        val d = calculateDistanceUseCase(g.first, g.second, f.latitude, f.longitude)
        _distance.value = d

        if (d > 1000) {  // Si está a más de 1km, pierde una vida
            _lives.value -= 1
            if (_lives.value <= 0) {
                handleLoss()
            }
            // Si le quedan vidas, puede intentarlo de nuevo
            return@launch
        }

        _score.value = calculateScoreUseCase(d)
        saveSession()
        _gameState.value = GameState.Finished
    }
}

