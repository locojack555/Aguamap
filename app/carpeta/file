override suspend fun getTrimesterRanking(): List<UserRanking> {
    val calendar = Calendar.getInstance()
    val mesActual = calendar.get(Calendar.MONTH) + 1
    val añoActual = calendar.get(Calendar.YEAR)
    val idUsuarioActual = authRepository.getCurrentUserUid()

    // Calculamos los 3 meses del trimestre actual
    val mesesTrimestre = when (mesActual) {
        in 1..3  -> listOf(1, 2, 3)
        in 4..6  -> listOf(4, 5, 6)
        in 7..9  -> listOf(7, 8, 9)
        else     -> listOf(10, 11, 12)
    }

    val snapshot = db.collection("monthlyRanking")
        .whereEqualTo("year", añoActual)
        .whereIn("month", mesesTrimestre)
        .get()
        .await()

    return snapshot.documents
        .groupBy { it.getString("userId") ?: "" }
        .map { (userId, documentos) ->
            UserRanking(
                position = 0,
                name = documentos.firstOrNull()?.getString("userName")?.takeIf { it.isNotBlank() } ?: "Jugador",
                points = documentos.sumOf { it.getLong("totalScore") ?: 0L }.toInt(),
                discovered = documentos.sumOf { it.getLong("totalDiscovered") ?: 0L }.toInt(),
                games = documentos.sumOf { it.getLong("gamesCount") ?: 0L }.toInt(),
                isCurrentUser = userId == idUsuarioActual
            )
        }
        .sortedByDescending { it.points }
        .take(10)
        .mapIndexed { index, usuario -> usuario.copy(position = index + 1) }
}

